# Pexels (video)
PEXELS_API_KEY=

# Pixabay (music)
PIXABAY_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# YouTube OAuth (filled after running auth flow)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Bot settings
POSTING_HOUR=8          # Hour in UTC to post daily
CANDIDATES_PER_RUN=20   # How many clips to fetch and score per cycle
MIN_QUALITY_SCORE=7     # Minimum Claude score (1-10) to pass
MANUAL_REVIEW=true      # Set to false to skip human review queue
